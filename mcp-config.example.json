{
  "servers": {
    "email": {
      "command": "node",
      "args": ["mcp-servers/email-mcp/index.js"],
      "env": {
        "GMAIL_CREDENTIALS_PATH": "credentials.json",
        "GMAIL_TOKEN_PATH": "token.pickle"
      },
      "disabled": false
    },
    "linkedin": {
      "command": "node",
      "args": ["mcp-servers/linkedin-mcp/index.js"],
      "env": {
        "LINKEDIN_SESSION_PATH": "linkedin_session",
        "HEADLESS": "true"
      },
      "disabled": false
    },
    "facebook": {
      "command": "node",
      "args": ["mcp-servers/facebook-mcp/index.js"],
      "env": {
        "FACEBOOK_PAGE_ACCESS_TOKEN": "YOUR_PAGE_ACCESS_TOKEN_HERE",
        "FACEBOOK_PAGE_ID": "YOUR_PAGE_ID_HERE"
      },
      "disabled": false
    },
    "twitter": {
      "command": "node",
      "args": ["mcp-servers/twitter-mcp/index.js"],
      "env": {
        "TWITTER_BEARER_TOKEN": "YOUR_BEARER_TOKEN_HERE"
      },
      "disabled": true
    },
    "odoo": {
      "command": "node",
      "args": ["mcp-servers/odoo-mcp/index.js"],
      "env": {
        "ODOO_URL": "http://localhost:8069",
        "ODOO_DB": "odoo_db",
        "ODOO_EMAIL": "admin@example.com",
        "ODOO_PASSWORD": "YOUR_ODOO_PASSWORD_HERE"
      },
      "disabled": false
    },
    "filesystem": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-filesystem", "personal-ai-employee"],
      "disabled": false
    }
  },
  "settings": {
    "email": {
      "require_approval_for_send": true,
      "require_approval_for_new_contacts": true,
      "auto_send_to_known_contacts": false
    },
    "linkedin": {
      "require_approval_for_posts": true,
      "require_approval_for_connection_requests": true,
      "auto_comment": false
    },
    "facebook": {
      "require_approval_for_posts": true,
      "max_posts_per_day": 5
    },
    "instagram": {
      "require_approval_for_posts": true,
      "max_posts_per_day": 3
    },
    "twitter": {
      "require_approval_for_posts": true,
      "max_tweets_per_day": 10
    },
    "odoo": {
      "require_approval_for_invoices": true,
      "require_approval_for_payments": true,
      "auto_approve_invoices_under": 500
    }
  }
}